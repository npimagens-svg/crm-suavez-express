# Sua Vez Express — variáveis do FRONTEND (Vite). Estas são PÚBLICAS por
# natureza (vão no bundle do navegador). NUNCA coloque service_role aqui.
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Segredos de SERVIDOR NÃO ficam em .env do front. Eles vão em:
#  - Supabase Secrets (Edge Functions): ASAAS_KEY, ASAAS_WEBHOOK_TOKEN,
#    RESEND_API_KEY, EVOLUTION_KEY, CRON_SECRET, SUPABASE_SERVICE_ROLE_KEY.
#  - Tabela backend-only salon_secrets: chaves Asaas/Z-API por salão.
